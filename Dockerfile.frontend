# ============================================
# Alalloy Agent 前端 Dockerfile
# 铝合金智能设计系统 v2.0 - Nuxt 静态构建
# ============================================

# ==================== 构建阶段 ====================
FROM node:20-alpine AS builder

WORKDIR /app

# 声明构建时环境变量
ARG VITE_BACKEND_HOST=backend
ARG VITE_BACKEND_PORT=8001
ARG VITE_API_BASE_URL
ARG VITE_WS_BASE_URL
ARG DEV_MODE=false

# 复制 package 文件
COPY frontend/package*.json ./

# 安装依赖
RUN npm install --ignore-scripts

# 复制前端源代码
COPY frontend/ .

# 写入构建时环境变量
RUN echo "VITE_BACKEND_HOST=${VITE_BACKEND_HOST}" > .env && \
    echo "VITE_BACKEND_PORT=${VITE_BACKEND_PORT}" >> .env && \
    echo "DEV_MODE=${DEV_MODE}" >> .env && \
    if [ -n "${VITE_API_BASE_URL}" ]; then echo "VITE_API_BASE_URL=${VITE_API_BASE_URL}" >> .env; fi && \
    if [ -n "${VITE_WS_BASE_URL}" ]; then echo "VITE_WS_BASE_URL=${VITE_WS_BASE_URL}" >> .env; fi

# 构建静态产物（SSR 已关闭，输出 .output/public）
RUN npm run generate

# ==================== 运行阶段 ====================
FROM nginx:1.25-alpine

# 创建非 root 用户
RUN addgroup -g 1001 -S appuser && \
    adduser -S -D -H -u 1001 -h /var/cache/nginx -s /sbin/nologin -G appuser appuser

# 复制 Nginx 配置
COPY nginx-main.conf /etc/nginx/nginx.conf
COPY nginx.conf /etc/nginx/conf.d/default.conf

# 清理 Nginx 默认静态文件
RUN rm -rf /usr/share/nginx/html/*

# 从构建阶段复制构建产物
COPY --from=builder /app/.output/public /usr/share/nginx/html

# 调整权限
RUN chown -R appuser:appuser /usr/share/nginx/html && \
    chown -R appuser:appuser /var/cache/nginx && \
    chown -R appuser:appuser /var/log/nginx && \
    touch /var/run/nginx.pid && \
    chown -R appuser:appuser /var/run/nginx.pid

USER appuser

# 健康检查
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:80/ || exit 1

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
