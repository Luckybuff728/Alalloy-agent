# =================================================================
# Alalloy Agent v2.0 前端环境变量配置文件
# =================================================================

# -----------------------------------------------------------------
# 1. 开发模式配置
# -----------------------------------------------------------------
# 开发模式 (true: 跳过 IAM 认证，使用本地测试 Token / false: 正常 OIDC 认证)
# 注意：必须与后端 .env 中的 DEV_MODE 保持一致
VITE_DEV_MODE=true

# -----------------------------------------------------------------
# 2. 前端服务配置
# -----------------------------------------------------------------
# 前端服务监听端口
VITE_DEV_PORT=5174

# -----------------------------------------------------------------
# 3. 后端服务配置
# -----------------------------------------------------------------
# 后端服务配置 (必须与后端 .env 中的 BACKEND_PORT 保持一致)
VITE_BACKEND_HOST=localhost
VITE_BACKEND_PORT=8001

# -----------------------------------------------------------------
# 4. Supabase 配置
# -----------------------------------------------------------------
# Supabase 项目 URL (铝合金 Agent 专用项目)
SUPABASE_URL=https://fyonyyermialezvlvamv.supabase.co
# Supabase 匿名密钥 (anon key) - 前端使用
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZ5b255eWVybWlhbGV6dmx2YW12Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzExMzg0OTksImV4cCI6MjA4NjcxNDQ5OX0.IJDwo0qbi8dsnPKSQnIMaVXy_qSPdozG3WucnWTpjSc

# -----------------------------------------------------------------
# 5. LangSmith 配置
# -----------------------------------------------------------------
# LangSmith API 密钥 (用于 Agent 调试和跟踪)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=alalloy-agent

# -----------------------------------------------------------------
# 6. TopMaterial API
# -----------------------------------------------------------------
# TopMaterial 平台 API (热力学计算、ML 预测等)
TOPMAT_API_URL=https://api.topmaterial-tech.com

# -----------------------------------------------------------------
# 7. Nuxt Public 变量
# -----------------------------------------------------------------
# 后端 REST API 地址
NUXT_PUBLIC_API_URL=http://localhost:8001
# 后端 WebSocket 地址
NUXT_PUBLIC_WS_URL=ws://localhost:8001
