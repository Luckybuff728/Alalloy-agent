# =================================================================
# Alalloy Agent v2.0 — 部署配置模板
# =================================================================
# ★ 使用前：将 SERVER_IP:8080 替换为实际服务器地址
#   如有宿主机 Nginx 且绑定了 80 端口，则用 http://IP 或 http://域名
# =================================================================

# -----------------------------------------------------------------
# 1. 服务器地址（★ 必须改）
# -----------------------------------------------------------------
FRONTEND_URL=http://SERVER_IP:8080
FRONTEND_CALLBACK_URL=http://SERVER_IP:8080/callback
BACKEND_CALLBACK_URL=http://SERVER_IP:8001/api/auth/callback

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001

# -----------------------------------------------------------------
# 2. 运行模式
# -----------------------------------------------------------------
# false = 生产模式（使用 Supabase/FerrisKey 认证）
# true  = 开发模式（跳过认证，直接进入）
DEV_MODE=false

# DEV_MODE=true 时的测试用户（生产忽略）
DEV_USER_ID=dev-user-0001
DEV_USER_EMAIL=dev@topmaterial-tech.com
DEV_USER_NAME=开发测试用户
DEV_JWT_SECRET=请替换为随机字符串

# -----------------------------------------------------------------
# 3. LLM（★ 必须填）
# -----------------------------------------------------------------
DASHSCOPE_API_KEY=sk-xxx
DASHSCOPE_MODEL_NAME=qwen3.5-plus

# -----------------------------------------------------------------
# 4. MCP 计算服务（★ 替换为公司服务器地址）
# -----------------------------------------------------------------
# 宿主机上的服务：http://host.docker.internal:端口/mcp（容器内访问宿主机）
# 公司服务器的服务：http://192.168.x.x:端口/mcp
MCP_URL=http://host.docker.internal:3000/mcp
MCP_TOKEN=your-mcp-token
MCP_TRANSPORT=streamable_http

# -----------------------------------------------------------------
# 5. Supabase 认证（使用 Supabase 邮箱登录必须配置）
# -----------------------------------------------------------------
SUPABASE_AUTH_ENABLED=true
SUPABASE_URL=https://fyonyyermialezvlvamv.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_JWT_SECRET=xxx
SUPABASE_DB_URL=postgresql://postgres.xxx:密码@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# 构建前端镜像时也会用到（从此文件读取）
NUXT_PUBLIC_AUTH_PROVIDER=both

# -----------------------------------------------------------------
# 6. FerrisKey SSO（使用企业 SSO 登录时配置，不用可留空）
# -----------------------------------------------------------------
FERRISKEY_URL=https://ferriskey-api.topmatdev.com
FERRISKEY_REALM=topmat-public
FERRISKEY_CLIENT_ID=alalloy-agent
FERRISKEY_CLIENT_SECRET=从FerrisKey管理后台获取
VERIFY_SSL=true

# -----------------------------------------------------------------
# 7. 华为云 IDME（性能预测 API）
# -----------------------------------------------------------------
HUAWEI_IAM_URL=https://iam.cn-north-4.myhuaweicloud.com/v3/auth/tokens
HUAWEI_DOMAIN_NAME=Topmaterial_Tech
HUAWEI_USER_NAME=Topmaterial_Tech
HUAWEI_PASSWORD=xxx
IDME_API_URL=https://idme.cn-southwest-2.huaweicloud.com/linkx-f-scriptengine/linkx_se/services/ScriptEngine/v1/api/external/Composition2property?envType=Pro
IDME_TENANT_ID=44

# -----------------------------------------------------------------
# 8. TopMatStudio（热力学计算 API）
# -----------------------------------------------------------------
TOPMAT_API_URL=https://api.topmaterial-tech.com
TOPMAT_TOKEN=Authorization=Bearer xxx
