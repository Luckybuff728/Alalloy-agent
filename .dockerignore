# Python 缓存
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/*.so
**/.Python
**/*.egg-info/

# 虚拟环境
venv/
.venv/
env/

# Node.js 依赖（大量文件，构建时单独 npm install）
frontend/node_modules/
web/node_modules/

# 前端构建产物
frontend/.nuxt/
frontend/.output/
frontend/dist/
web/.nuxt/
web/.output/
web/dist/

# 日志
logs/
*.log

# 测试和报告
backend/reports/
backend/test_*.py
backend/check_*.py

# 开发工具
.vscode/
.idea/
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db

# 环境变量（不打入镜像）
.env
frontend/.env

# Git
.git/
.gitignore
