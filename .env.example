# ==================== 铝合金智能设计系统 v2.0 配置 ====================

# ---------- 服务配置 ----------
BACKEND_PORT=8001
BACKEND_HOST=0.0.0.0
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000

# ---------- LLM 配置（DashScope 百炼 API） ----------
# 从 https://dashscope.console.aliyun.com/ 获取
DASHSCOPE_API_KEY=sk-xxx

# ---------- MCP 服务器配置（ONNX + Calphad） ----------
MCP_URL=http://111.22.21.99:10001/mcp
MCP_TOKEN=your-mcp-token
MCP_TRANSPORT=streamable_http

# ---------- 华为云 IDME API 配置 ----------
HUAWEI_IAM_URL=https://iam.cn-north-4.myhuaweicloud.com/v3/auth/tokens
HUAWEI_DOMAIN_NAME=Topmaterial_Tech
HUAWEI_USER_NAME=Topmaterial_Tech
HUAWEI_PASSWORD=xxx
IDME_API_URL=https://idme.cn-southwest-2.huaweicloud.com/linkx-f-scriptengine/linkx_se/services/ScriptEngine/v1/api/external/Composition2property?envType=Pro
IDME_TENANT_ID=44

# ---------- Supabase 配置（会话持久化，后续启用） ----------
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_KEY=xxx
# SUPABASE_POSTGRES_URL=postgresql://postgres:xxx@db.xxx.supabase.co:5432/postgres

# ---------- 认证配置（后续启用） ----------
