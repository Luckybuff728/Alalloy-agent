# -----------------------------------------------------------------
# 1. 核心 LLM 配置 (必需)
# -----------------------------------------------------------------
# 阿里云百炼 API 密钥
DASHSCOPE_API_KEY=sk-7f3a8323240c43b1a7ebf4ac6a3a1b69
# 模型名称
DASHSCOPE_MODEL_NAME=qwen-plus

# -----------------------------------------------------------------
# 2. 认证配置 (FerrisKey OIDC + Supabase)
# -----------------------------------------------------------------
# FerrisKey OIDC 配置
FERRISKEY_URL=https://ferriskey-api.topmatdev.com
FERRISKEY_REALM=topmat-public
FERRISKEY_CLIENT_ID=alalloy-agent
# [必须配置] 请填写从 FerrisKey 管理后台获取的 Client Secret
FERRISKEY_CLIENT_SECRET=

# OIDC 回调地址
FRONTEND_CALLBACK_URL=http://localhost:5174/callback
BACKEND_CALLBACK_URL=http://localhost:8001/api/auth/callback

# SSL 验证 (开发环境可关闭以支持自签证书)
VERIFY_SSL=false

# Supabase JWT Secret (用于签发 Supabase 自定义 Token)
SUPABASE_JWT_SECRET=xuIoInSYrFQlRzv4o8OTGaHV/hpHPX4yuHUjCiDeVwyCn0qcTgZB2aLo4ZsNwqjPe2ysofX6xsYIUUT/O7x2bw==

# -----------------------------------------------------------------
# 3. 服务器运行配置
# -----------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001
FRONTEND_URL=http://localhost:5174

# 开发模式 (true: 跳过 IAM 认证，使用本地测试 Token / false: 正常 OIDC 认证)
# 当 FerrisKey IAM 不可用时，设置为 true 可直接进入系统
DEV_MODE=true

# DEV_MODE 测试用户配置 (仅 DEV_MODE=true 时生效)
DEV_USER_ID=dev-user-0001
DEV_USER_EMAIL=dev@topmaterial-tech.com
DEV_USER_NAME=开发测试用户
# DEV_MODE 本地 JWT 签名密钥 (仅用于测试 Token，切勿在生产环境使用)
DEV_JWT_SECRET=alalloy-dev-secret-change-in-production

