# ============================================
# Alalloy Agent 前端 Dockerfile
# 铝合金智能设计系统 v2.0 — 本地构建 + Push Registry
# ============================================

# ==================== 构建阶段 ====================
FROM node:20-alpine AS builder

WORKDIR /app

# Supabase 公开凭据（anon key 是公开客户端凭据，可安全内嵌）
# 若切换 Supabase 项目，通过 docker-compose build args 覆盖即可
ARG NUXT_PUBLIC_SUPABASE_URL="https://fyonyyermialezvlvamv.supabase.co"
ARG NUXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZ5b255eWVybWlhbGV6dmx2YW12Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzExMzg0OTksImV4cCI6MjA4NjcxNDQ5OX0.IJDwo0qbi8dsnPKSQnIMaVXy_qSPdozG3WucnWTpjSc"
ARG NUXT_PUBLIC_AUTH_PROVIDER="both"

# 传给 nuxt generate（SPA 静态生成时读取）
ENV NUXT_PUBLIC_SUPABASE_URL=$NUXT_PUBLIC_SUPABASE_URL
ENV NUXT_PUBLIC_SUPABASE_ANON_KEY=$NUXT_PUBLIC_SUPABASE_ANON_KEY
ENV NUXT_PUBLIC_AUTH_PROVIDER=$NUXT_PUBLIC_AUTH_PROVIDER

# VITE_BACKEND_HOST 留空 → 前端使用相对路径 /api/ /ws/
# 前端容器内的 Nginx 代理到 backend:8001（Docker 内网）
ENV VITE_BACKEND_HOST=""
ENV VITE_DEV_MODE="false"

# 换 npmmirror（加速国内 npm install）
RUN npm config set registry https://registry.npmmirror.com

COPY frontend/package*.json ./
RUN npm install --ignore-scripts

COPY frontend/ .

# 增加 Node 堆内存（大型项目构建防 OOM）
ENV NODE_OPTIONS="--max-old-space-size=3072"
RUN npm run generate

# ==================== 运行阶段 ====================
FROM nginx:1.25-alpine

# 创建非 root 用户
RUN addgroup -g 1001 -S appuser && \
    adduser -S -D -H -u 1001 -h /var/cache/nginx -s /sbin/nologin -G appuser appuser

# 放置 Nginx 配置（nginx-main.conf + nginx.conf 已在项目根目录）
COPY nginx-main.conf /etc/nginx/nginx.conf
COPY nginx.conf /etc/nginx/conf.d/default.conf

# 清理默认页面，放入构建产物
RUN rm -rf /usr/share/nginx/html/*
COPY --from=builder /app/.output/public /usr/share/nginx/html

# 调整权限
RUN chown -R appuser:appuser /usr/share/nginx/html && \
    chown -R appuser:appuser /var/cache/nginx && \
    chown -R appuser:appuser /var/log/nginx && \
    touch /var/run/nginx.pid && \
    chown -R appuser:appuser /var/run/nginx.pid

USER appuser

HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:80/ || exit 1

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
