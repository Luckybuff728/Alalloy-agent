# =================================================================
# Alalloy Agent v2.0 前端【生产构建】环境变量
# 运行 npm run generate / npm run build 时自动使用此文件
# 会覆盖 .env 中的同名变量
# =================================================================

# 生产环境不直连后端，使用 Nginx 反代的相对路径 /api /ws
# 明确设为空字符串，覆盖 .env 中的 localhost
VITE_BACKEND_HOST=
NUXT_PUBLIC_API_URL=
NUXT_PUBLIC_WS_URL=
